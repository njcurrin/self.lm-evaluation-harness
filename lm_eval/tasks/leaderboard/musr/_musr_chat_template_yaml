dataset_path: TAUR-Lab/MuSR
output_type: generate_until
doc_to_text: !function utils.doc_to_text_chat
doc_to_target: !function utils.doc_to_target_chat
num_fewshot: 0
generation_kwargs:
  max_gen_toks: 1024
  until:
    - "</s>"
  do_sample: false
  temperature: 0.0
metric_list:
  - metric: exact_match
    aggregation: mean
    higher_is_better: true
    ignore_case: true
    ignore_punctuation: true
filter_list:
  - name: get_response
    filter:
      - function: "regex"
        regex_pattern: "(?i)(?:^|\\b)(\\d+)(?:\\b|$)"
        group_select: -1
      - function: take_first
metadata:
  version: 1.0
